{
  "name": "kongli.sh",
  "version": "1.0.0",
  "description": "Scroll through all 11,172 Hangul syllables with live jamo decomposition and encodings.",
  "homepage": "https://kongli.sh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vreid/kongli.sh.git"
  },
  "bugs": {
    "url": "https://github.com/vreid/kongli.sh/issues"
  },
  "license": "MIT",
  "author": "vreid",
  "keywords": [
    "korean",
    "hangul",
    "unicode",
    "jamo",
    "mithril",
    "bun",
    "unocss"
  ],
  "private": true,
  "scripts": {
    "dev": "bun run dev.ts",
    "build": "bun run build.ts",
    "test": "bun test",
    "lint": "oxlint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "bun run format:check && bun run lint && bun test",
    "og": "bun run scripts/gen-og.ts",
    "upgrade": "bun upgrade && bunx actions-up -y",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run format:check && bun run lint"
  },
  "dependencies": {
    "@unocss/reset": "^66.6.8",
    "mithril": "^2.3.8"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.98",
    "@types/bun": "^1.3.12",
    "@types/mithril": "^2.2.8",
    "oxlint": "^1.60.0",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "unocss": "^66.6.8"
  }
}
